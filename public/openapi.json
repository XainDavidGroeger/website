{
  "openapi": "3.1.0",
  "info": {
    "title": "VoltGrid Charging API — Sandbox",
    "version": "1.0.0",
    "description": "Demo-API von **VoltGrid**, einer fiktiven E-Ladesäulen-Plattform — mein durchgestochenes Fallbeispiel (API · UI-Kit · Architektur). Die Endpunkte laufen wirklich, es wird nichts gespeichert.\n\nDemo API of **VoltGrid**, a fictional EV charging platform — my end-to-end case study. The endpoints are live, nothing is persisted.",
    "contact": {
      "name": "David Gröger",
      "url": "https://david-webdev.de"
    }
  },
  "servers": [{ "url": "/" }],
  "tags": [
    { "name": "stations", "description": "Ladesäulen durchsuchen und abrufen" },
    { "name": "sessions", "description": "Lade-Sessions starten (Demo, ohne Persistenz)" }
  ],
  "paths": {
    "/api/v1/stations": {
      "get": {
        "tags": ["stations"],
        "summary": "Ladesäulen auflisten",
        "description": "Liste aller Säulen, optional gefiltert nach Stadt, Status, Stecker-Typ und Mindestleistung.",
        "parameters": [
          { "name": "city", "in": "query", "schema": { "type": "string" }, "example": "Hamburg" },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["available", "charging", "maintenance"] } },
          { "name": "connector", "in": "query", "schema": { "type": "string", "enum": ["CCS", "CHAdeMO", "Typ2"] } },
          { "name": "minPowerKw", "in": "query", "schema": { "type": "integer" }, "example": 150 },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 50, "default": 50 } }
        ],
        "responses": {
          "200": {
            "description": "Gefilterte Säulen-Liste",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/Station" } },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "count": { "type": "integer" },
                        "total": { "type": "integer" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/stations/{id}": {
      "get": {
        "tags": ["stations"],
        "summary": "Einzelne Säule abrufen",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "example": 1 }
        ],
        "responses": {
          "200": {
            "description": "Die Säule",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "data": { "$ref": "#/components/schemas/Station" } }
                }
              }
            }
          },
          "404": { "description": "Säule nicht gefunden" }
        }
      }
    },
    "/api/v1/sessions": {
      "post": {
        "tags": ["sessions"],
        "summary": "Lade-Session starten",
        "description": "Validiert Säule, Stecker und Energiemenge und startet die Session. Demo: nichts wird gespeichert, keine Säule startet wirklich. Tipp: Säule 4 ist in Wartung, Säule 2 besetzt — probier die Fehlerfälle aus.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SessionRequest" },
              "example": { "stationId": 1, "connectorType": "CCS", "estimatedKwh": 40 }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Session gestartet",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "data": { "$ref": "#/components/schemas/Session" } }
                }
              }
            }
          },
          "422": {
            "description": "Validierungsfehler",
            "content": {
              "application/json": {
                "example": { "statusCode": 422, "statusMessage": "Validation Failed", "data": { "errors": { "stationId": "station is under maintenance" } } }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Connector": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["CCS", "CHAdeMO", "Typ2"] },
          "powerKw": { "type": "integer", "example": 150 }
        }
      },
      "Station": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "name": { "type": "string", "example": "Hafenstraße 12" },
          "city": { "type": "string", "example": "Hamburg" },
          "status": { "type": "string", "enum": ["available", "charging", "maintenance"] },
          "connectors": { "type": "array", "items": { "$ref": "#/components/schemas/Connector" } },
          "pricePerKwhCents": { "type": "integer", "example": 49 },
          "uptimePercent": { "type": "number", "example": 99.2 }
        }
      },
      "SessionRequest": {
        "type": "object",
        "required": ["stationId", "connectorType", "estimatedKwh"],
        "properties": {
          "stationId": { "type": "integer" },
          "connectorType": { "type": "string", "enum": ["CCS", "CHAdeMO", "Typ2"] },
          "estimatedKwh": { "type": "integer", "minimum": 1, "maximum": 150 }
        }
      },
      "Session": {
        "type": "object",
        "properties": {
          "sessionId": { "type": "string", "example": "chg_x7k2m9qa" },
          "stationId": { "type": "integer" },
          "station": { "type": "string" },
          "connectorType": { "type": "string" },
          "estimatedKwh": { "type": "integer" },
          "estimatedCostCents": { "type": "integer", "example": 1960 },
          "status": { "type": "string", "example": "charging" },
          "note": { "type": "string" }
        }
      }
    }
  }
}
